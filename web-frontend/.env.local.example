# ================================================================
# web-frontend — variables de entorno
# FIX: añadidos VITE_MS2_URL ... VITE_MS5_URL
# La rúbrica exige consumir los 5 microservicios con al menos 2
# métodos REST cada uno.
# ================================================================

# Google OAuth (para login con Google)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# API Gateway (URL pública HTTPS de AWS — misma base para todos los MSs)
VITE_API_GATEWAY_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# URLs individuales por microservicio (en producción apuntan al API Gateway)
# En desarrollo local apuntan directamente a cada puerto
VITE_MS1_URL=http://localhost:3001
VITE_MS2_URL=http://localhost:3002
VITE_MS3_URL=http://localhost:3003
VITE_MS4_URL=http://localhost:3004
VITE_MS5_URL=http://localhost:3005

# Orquestador (si lo usas para rutas que requieren RBAC)
VITE_ORCHESTRATOR_URL=http://localhost:3000
